    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center w-full">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
        
        <!-- Center modal -->
        <div class="relative inline-block bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all max-w-lg w-full mx-auto">
            <!-- Modal header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white" id="sub-entry-modal-title">
                    <%= __('diary.addSubEntry') || 'Add Sub-Entry' %>
                </h3>
                <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200" onclick="closeModal('add-sub-entry-modal')">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            
            <!-- Modal content -->
            <div class="px-6 py-4">
                <form id="add-sub-entry-form" class="space-y-6">
                    <input type="hidden" id="sub-entry-parent-id">
                    
                    <!-- Entry Content -->
                    <%- include('partials/components/input', { 
                        type: 'textarea',
                        id: 'sub-entry-content',
                        label: __('diary.content'),
                        placeholder: __('diary.contentPlaceholder'),
                        required: true,
                        rows: 4
                    }) %>
                    
                    <!-- Priority Selection -->
                    <%- include('partials/components/input', { 
                        type: 'select',
                        id: 'sub-entry-priority',
                        label: __('relevance.label'),
                        options: [
                            { value: '1', label: __('relevance.levels.1') },
                            { value: '2', label: __('relevance.levels.2') },
                            { value: '3', label: __('relevance.levels.3') },
                            { value: '4', label: __('relevance.levels.4') },
                            { value: '5', label: __('relevance.levels.5') }
                        ]
                    }) %>
                    
                    <!-- Tag Selection -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">
                            <%= __('diary.tags') %>
                        </label>
                        <div id="sub-entry-tag-selection" class="flex flex-wrap gap-2 mb-3 min-h-[2.5rem] p-3 border border-gray-300 dark:border-gray-600 rounded-md bg-gray-50 dark:bg-gray-700">
                            <!-- Available tags will be loaded here -->
                        </div>
                    </div>

                    <div class="flex justify-end space-x-3 pt-4">
                        <%- include('partials/components/button', { 
                            text: __('components.button.cancel'),
                            variant: 'outline',
                            type: 'button',
                            onclick: 'closeModal("add-sub-entry-modal")'
                        }) %>
                        <%- include('partials/components/button', { 
                            text: __('diary.save'),
                            variant: 'primary',
                            type: 'submit'
                        }) %>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Enhanced JavaScript -->
<script src="/js/diary.js"></script>

<%- include('partials/footer') %>

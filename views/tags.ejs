<%- include('partials/header', { title: __('tags.title') || 'Tags' }) %>

<!-- Page Header -->
<div class="mb-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
                <%= __('tags.title') || 'Tag Management' %>
            </h1>
            <p class="mt-2 text-gray-600 dark:text-gray-400">
                <%= __('tags.subtitle') || 'Create and manage tags for organizing your diary entries' %>
            </p>
        </div>        <div class="flex items-center space-x-3">
            <%- include('partials/components/button', { 
                text: __('tags.addTag') || 'Add Tag',
                variant: 'primary',
                onclick: 'openModal("add-tag-modal")',
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>'
            }) %>
            <%- include('partials/components/button', { 
                text: __('tags.backToDiary') || 'Back to Diary',
                variant: 'outline',
                href: '/diary',
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>'
            }) %>
        </div>
    </div>
</div>



<!-- Tags List -->
<div class="mb-8">
    <div class="card-content">
        <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-white">
            <%= __('tags.existingTags') || 'Your Tags' %>
        </h2>
        <div class="flex items-center space-x-4">
            <div class="relative">
                <input
                    type="text"
                    id="search-tags"
                    placeholder="<%= __('tags.searchPlaceholder') || 'Search tags...' %>"
                    class="px-3 py-2 pl-8 text-sm border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
                >
                <svg class="absolute left-2 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>
        </div>
    </div>
      <!-- Loading State -->
    <div id="tags-loading" class="hidden">
        <%- include('partials/components/loading', { 
            text: __('tags.loading') || 'Loading tags...' 
        }) %>
    </div>

    <!-- Empty State -->
    <div id="tags-empty" class="hidden">
        <%- include('partials/components/empty-state', { 
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>',
            title: __('tags.noTags') || 'No tags yet',
            description: __('tags.noTagsDescription') || 'Create your first tag to start organizing your diary entries.'
        }) %>
    </div>
    
    <!-- Tags Grid -->
    <div id="tags-grid" class="hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Tags will be populated here -->
        </div>
    </div>
    </div>
</div>

<!-- Add Tag Modal -->
<div id="add-tag-modal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center w-full">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
        <div class="relative inline-block bg-white dark:bg-gray-800 rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all max-w-lg w-full mx-auto">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white">
                    <%= __('tags.addTag') || 'Create New Tag' %>
                </h3>
                <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200" onclick="closeModal('add-tag-modal')">
                    <span class="sr-only">Close</span>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="modal-content">                <form id="add-tag-form" class="space-y-4">
                    <%- include('partials/components/input', { 
                        type: 'text',
                        id: 'tag-name',
                        label: __('tags.name') || 'Tag Name',
                        placeholder: __('tags.namePlaceholder') || 'Enter tag name',
                        required: true
                    }) %>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                            <%= __('tags.color') || 'Color' %>
                        </label>
                        <div class="flex items-center space-x-2">
                            <div class="relative w-12 h-10 border border-gray-300 dark:border-gray-600 rounded-md overflow-hidden cursor-pointer">
                                <input
                                    type="color"
                                    id="tag-color"
                                    value="#3b82f6"
                                    class="absolute inset-0 w-full h-full scale-150 cursor-pointer border-0 outline-0"
                                    style="transform: scale(1.5); border: none; outline: none;"
                                >
                            </div>
                            <input
                                type="text"
                                id="tag-color-hex"
                                value="#3b82f6"
                                class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
                                pattern="^#[0-9A-Fa-f]{6}$"
                                placeholder="#3b82f6"
                            >
                        </div>
                    </div>

                    <div class="flex justify-end gap-2 pt-4">
                        <%- include('partials/components/button', { 
                            text: __('tags.cancel') || 'Cancel',
                            variant: 'outline',
                            onclick: 'closeModal("add-tag-modal")'
                        }) %>
                        <%- include('partials/components/button', { 
                            text: __('tags.createTag') || 'Create Tag',
                            variant: 'primary',
                            type: 'submit'
                        }) %>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Usage Stats Modal -->
<div id="stats-modal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0 w-full">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:w-full max-w-lg sm:p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white">
                    <%= __('tags.usageStats') || 'Tag Usage Statistics' %>
                </h3>
                <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200" onclick="closeModal('stats-modal')">
                    <span class="sr-only">Close</span>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="modal-content">
                <div id="stats-content" class="space-y-3">
                    <!-- Stats will be populated here -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Tag Modal -->
<div id="edit-tag-modal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0 w-full">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:w-full max-w-lg sm:p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white">
                    <%= __('tags.editTag') || 'Edit Tag' %>
                </h3>
                <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200" onclick="closeModal('edit-tag-modal')">
                    <span class="sr-only">Close</span>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="modal-content">
                <form id="edit-tag-form" class="space-y-4">
                    <input type="hidden" id="edit-tag-id">
                    <%- include('partials/components/input', { 
                        type: 'text',
                        id: 'edit-tag-name',
                        label: __('tags.name') || 'Tag Name',
                        required: true
                    }) %>
                      <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                            <%= __('tags.color') || 'Color' %>
                        </label>
                        <div class="flex items-center space-x-2">
                            <div class="relative w-12 h-10 border border-gray-300 dark:border-gray-600 rounded-md overflow-hidden cursor-pointer">
                                <input
                                    type="color"
                                    id="edit-tag-color"
                                    class="absolute inset-0 w-full h-full scale-150 cursor-pointer border-0 outline-0"
                                    style="transform: scale(1.5); border: none; outline: none;"
                                >
                            </div>
                            <input
                                type="text"
                                id="edit-tag-color-text"
                                placeholder="#000000"
                                class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
                            >
                        </div>
                    </div>
                    
                    <div class="flex justify-end space-x-3 pt-4">
                        <%- include('partials/components/button', { 
                            text: __('tags.cancel') || 'Cancel',
                            variant: 'outline',
                            onclick: 'closeModal("edit-tag-modal")'
                        }) %>
                        <%- include('partials/components/button', { 
                            text: __('tags.saveChanges') || 'Save Changes',
                            variant: 'primary',
                            type: 'submit'
                        }) %>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="/js/tags.js"></script>

<%- include('partials/footer') %>

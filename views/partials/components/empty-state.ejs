<!-- Empty State Component -->

<div class="text-center <%= locals.removePadding ? '' : 'py-12' %>">
    <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-gray-100 dark:bg-gray-800 mb-4">
        <% if (locals.icon) { %>
            <svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <%- icon %>
            </svg>
        <% } else { %>
            <svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
        <% } %>
    </div>
    
    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">
        <%= locals.title || 'No items found' %>
    </h3>
    
    <% if (locals.description) { %>
        <p class="text-gray-600 dark:text-gray-400 mb-6 max-w-md mx-auto">
            <%= description %>
        </p>
    <% } %>
    
    <% if (locals.actionText && locals.actionHref) { %>
        <%- include('button', { 
            text: actionText, 
            href: actionHref, 
            variant: 'primary',
            icon: locals.actionIcon 
        }) %>
    <% } %>
</div>

<!-- Loading Component -->
<%
    const sizeVariants = {
        sm: 'h-4 w-4',
        md: 'h-8 w-8',
        lg: 'h-12 w-12'
    };
    
    const size = locals.size || 'md';
    const sizeClasses = sizeVariants[size] || sizeVariants.md;
    const text = locals.text || 'Loading...';
%>

<div class="flex flex-col items-center justify-center py-8" id ="<%= locals.id || 'loading-component' %>">
    <div class="animate-spin rounded-full <%= sizeClasses %> border-b-2 border-blue-600"></div>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400"><%= text %></p>
</div>

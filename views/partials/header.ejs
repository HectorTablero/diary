<!doctype html>
<html lang="<%= getLocale() %>">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" href="<%= baseURL %>/images/favicon.png" />
        <meta
            name="description"
            content="Personal diary application for organizing thoughts and memories" />
        <meta name="theme-color" content="#3b82f6" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="<%= baseURL %>/" />
        <meta property="og:title" content="<%= title %> - Diary" />
        <meta
            property="og:description"
            content="Personal diary application for organizing thoughts and memories" />
        <meta property="og:image" content="<%= baseURL %>/images/favicon.png" />
        <meta property="twitter:card" content="summary_large_small" />
        <meta property="twitter:url" content="<%= baseURL %>/" />
        <meta property="twitter:title" content="<%= title %> - Diary" />
        <meta
            property="twitter:description"
            content="Personal diary application for organizing thoughts and memories" />
        <meta property="twitter:image" content="<%= baseURL %>/images/favicon.png" />
        <title><%= title %> - Diary</title>
        <link href="/css/styles.css" type="text/css" rel="stylesheet" />
        <style id="scrollbar-style"></style>
        <script src="/js/theme.js"></script>
        <script src="/js/components.js"></script>
        <script defer src="/js/offline.js"></script>
    </head>
    <body class="flex min-h-screen flex-col bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-inter transition-colors duration-200">
        <%- include("navbar") %>
        <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
    </body>
</html>

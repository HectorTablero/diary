        "@types/cookie-parser": "^1.4.8",
        "@types/dotenv": "^6.1.1",
        "@types/express": "^5.0.2",
        "@types/express-session": "^1.18.1",
        "@types/mongoose": "^5.11.96",
        "@types/node": "^22.15.21",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.16",
        "autoprefixer": "^10.4.21",
        "body-parser": "^2.2.0",
        "connect-mongo": "^5.1.0",
        "cookie-parser": "^1.4.7",
        "dotenv": "^16.5.0",
        "ejs": "^3.1.10",
        "express": "^5.1.0",
        "express-session": "^1.18.1",
        "i18n": "^0.15.1",

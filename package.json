{
    "name": "diary",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "dev": "concurrently \"npm run watch-css\" \"nodemon\"",
        "start": "npm run build-css && ts-node -r tsconfig-paths/register src/index.ts",
        "build-css": "postcss views/styles.source.css -o public/css/styles.css",
        "watch-css": "postcss views/styles.source.css -o public/css/styles.css --watch"
    },

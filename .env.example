# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/diary

# Port the server (API + built SPA) listens on
PORT=3000

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URIs must include:
#   http://localhost:5173/api/auth/callback/google   (dev, through the Vite proxy)
#   https://<your-domain>/api/auth/callback/google   (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth (generate the secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# Public origin of the app: http://localhost:5173 in dev, https://<your-domain> in prod
BETTER_AUTH_URL=http://localhost:5173
